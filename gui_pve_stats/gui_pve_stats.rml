<rml>
<head>
    <title>PvE Stats</title>
    <link type="text/rcss" href="gui_pve_stats.rcss" />
</head>
<body id="pve-stats-widget">
    <div id="pve-stats-root" class="panel pve-stats-root" data-model="pve_stats_model">
        <div class="title-bar">
            <handle move_target="pve-stats-root" edge_margin="none">
                <div class="title-content">
                    <span class="title-text">PvE Stats</span>
                    <div id="pve-stats-status" class="title-status ctrl-btn active hidden" onclick="widget:CopyUpdateLink(event)" onmouseover="widget:ShowUpdateHelp(event)" onmouseout="widget:HideHelp(event)">Ready</div>
                </div>
            </handle>
            <div class="title-controls">
                <div id="pve-stats-diagnostics-toggle" class="ctrl-btn" onclick="widget:ToggleDiagnostics(event)" onmouseover="widget:ShowDiagnosticsHelp(event)" onmouseout="widget:HideHelp(event)">Diag</div>
                <div id="pve-stats-spectators-toggle" class="ctrl-btn" onclick="widget:ToggleSpectators(event)">Spec</div>
                <div id="pve-stats-minimize" class="ctrl-btn window-btn" onclick="widget:ToggleMinimized(event)">-</div>
                <div id="pve-stats-close" class="ctrl-btn window-btn close-btn" onclick="widget:CloseWindow(event)">x</div>
            </div>
        </div>

	<div id="pve-stats-content" class="pve-stats-content">
		<div id="pve-stats-loading" class="pve-stats-loading hidden">
			<div class="pve-stats-loading-track">
				<div id="pve-stats-loading-fill" class="pve-stats-loading-fill"></div>
			</div>
		</div>

        <div class="pve-stats-summary pve-stats-summary-compact">
            <div class="pve-stats-metric" onmouseover="widget:ShowWinChanceHelp(event)" onmouseout="widget:HideHelp(event)">
                <span id="pve-stats-exact-wins-label" class="pve-stats-label">Win Chance</span>
                <span id="pve-stats-exact-wins" class="pve-stats-value">-</span>
            </div>
            <div class="pve-stats-metric" onmouseover="widget:ShowDifficultyPercentileHelp(event)" onmouseout="widget:HideHelp(event)">
                <span id="pve-stats-evidence-games-label" class="pve-stats-label">Difficulty Percentile</span>
                <span id="pve-stats-evidence-games" class="pve-stats-value">-</span>
            </div>
            <div class="pve-stats-metric" onmouseover="widget:ShowTrainingGamesHelp(event)" onmouseout="widget:HideHelp(event)">
                <span class="pve-stats-label">Training Games</span>
                <span id="pve-stats-extended-wins" class="pve-stats-value">-</span>
            </div>
            <div class="pve-stats-metric" onmouseover="widget:ShowMatchHelp(event)" onmouseout="widget:HideHelp(event)">
                <span class="pve-stats-label">Match</span>
                <span id="pve-stats-match" class="pve-stats-value">-</span>
            </div>
        </div>

        <div id="pve-stats-histogram" class="pve-stats-histogram hidden">
            <div id="pve-stats-histogram-content"></div>
            <div id="pve-stats-histogram-caption" class="pve-stats-histogram-caption"></div>
        </div>

        <div id="pve-stats-help" class="pve-stats-help hidden"></div>

        <div id="pve-stats-source" class="pve-stats-source hidden">
            <span class="pve-stats-source-label">Data</span>
            <span id="pve-stats-source-window" class="pve-stats-source-value">-</span>
        </div>

        <div id="pve-stats-evidence-summary" class="pve-stats-evidence-summary hidden"></div>

        <div id="pve-stats-diagnostics" class="pve-stats-diagnostics hidden">
            <div class="pve-stats-diagnostics-header">
                <span>Diagnostics</span>
                <span class="pve-stats-diagnostics-copy" onclick="widget:CopyDiagnostics(event)">Copy</span>
            </div>
            <div id="pve-stats-diagnostics-content"></div>
        </div>

        <div id="pve-stats-diffs" class="pve-stats-diffs hidden"></div>

        <div class="table-area pve-stats-table">
            <div class="pve-stats-tabs">
                <div id="pve-stats-tab-awards" class="pve-stats-tab active" onclick="widget:SetPlayerTabAwards(event)">Awards</div>
                <div id="pve-stats-tab-encounters" class="pve-stats-tab" onclick="widget:SetPlayerTabEncounters(event)">Encounters</div>
                <div id="pve-stats-tab-adventures" class="pve-stats-tab" onclick="widget:SetPlayerTabAdventures(event)">Games &amp; Maps</div>
                <div id="pve-stats-tab-milestones" class="pve-stats-tab" onclick="widget:SetPlayerTabMilestones(event)">Milestones</div>
                <div id="pve-stats-tab-setup" class="pve-stats-tab" onclick="widget:SetPlayerTabSetup(event)">Lobby Settings</div>
            </div>
            <div class="table-header">
                <span id="pve-stats-player-label" class="pve-stats-th-player pve-stats-sortable" onclick="widget:SortPlayerColumnName(event)">Player</span>
                <span id="pve-stats-player-stat-one-label" class="pve-stats-th-stat pve-stats-sortable" onclick="widget:SortPlayerColumnOne(event)" onmouseover="widget:ShowPlayerStatOneHelp(event)" onmouseout="widget:HideHelp(event)">Setup Clears</span>
                <span id="pve-stats-player-stat-two-label" class="pve-stats-th-stat pve-stats-sortable" onclick="widget:SortPlayerColumnTwo(event)" onmouseover="widget:ShowPlayerStatTwoHelp(event)" onmouseout="widget:HideHelp(event)">Setup Plays</span>
                <span id="pve-stats-player-stat-three-label" class="pve-stats-th-stat pve-stats-sortable" onclick="widget:SortPlayerColumnThree(event)" onmouseover="widget:ShowPlayerStatThreeHelp(event)" onmouseout="widget:HideHelp(event)">PvE Games</span>
            </div>
            <div id="pve-stats-table-help" class="pve-stats-help pve-stats-table-help hidden"></div>
            <div id="pve-stats-players" class="pve-stats-players"></div>
        </div>

        <div id="pve-stats-error" class="pve-stats-error hidden"></div>
	</div>
    </div>
</body>
</rml>
